#!/command/with-contenv sh

set -eu

. /etc/colors.sh
. /etc/rclone-mount-lib.sh

PREFIX="[s6-rc] [rclone-mount-check]-up:"
CONFIG_PATH="$(config_path)"

if [ -z "${RemotePath}" ]; then
    printf '%b\n' "${PREFIX} ${Red}RemotePath is empty[ERROR]${Color_Off}"
    exit 1
fi

if [ ! -f "${CONFIG_PATH}" ]; then
    printf '%b\n' "${PREFIX} ${Red}missing rclone config at ${CONFIG_PATH}[ERROR]${Color_Off}"
    exit 1
fi

if [ -n "$(ls -A "${MountPoint}" 2>/dev/null)" ]; then
    printf '%b\n' "${PREFIX} ${Red}MountPoint folder not empty[ERROR]${Color_Off}"
    exit 1
fi

if mount_present; then
    printf '%b\n' "${PREFIX} ${Red}found other MountPoint in /proc/mounts${Color_Off}"
    exit 1
fi

printf '%b\n' "${PREFIX} ${Green}MountPoint ${MountPoint} is ready${Color_Off}"
